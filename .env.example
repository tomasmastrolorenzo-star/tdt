# Environment Variables

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Instagram API (RapidAPI)
# Get your API key from: https://rapidapi.com/hub
RAPIDAPI_KEY=your_rapidapi_key_here
INSTAGRAM_API_URL=https://instagram-scraper-stable-api.p.rapidapi.com

# JAP Provider (JustAnotherPanel)
JAP_API_KEY=your_jap_api_key_here
JAP_API_URL=your_jap_api_url_here
